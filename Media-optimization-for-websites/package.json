{
  "name": "media-optimization-script",
  "version": "1.0.0",
  "description": "Batch media optimization script for converting images and videos to optimal formats",
  "main": "convert-media.js",
  "type": "module",
  "scripts": {
    "start": "node convert-media.js",
    "optimize": "node convert-media.js --source ./public --output ./public-optimized",
    "optimize:dry": "node convert-media.js --source ./public --output ./public-optimized --dry-run",
    "optimize:continue": "node convert-media.js --source ./public --output ./public-optimized --continue",
    "optimize:images-only": "node convert-media.js --source ./public --skip-videos",
    "optimize:videos-only": "node convert-media.js --source ./public --skip-images"
  },
  "keywords": [
    "media",
    "optimization",
    "image",
    "video",
    "webp",
    "ffmpeg",
    "batch"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "sharp": "^0.33.0",
    "fluent-ffmpeg": "^2.1.3",
    "cli-progress": "^3.12.0",
    "chalk": "^5.3.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=18.0.0"
  }
}
